# Recipe Agent 配置示例
# 复制此文件为 .env 并填写实际值

# 应用配置
DEBUG=false

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/recipe_agent
REDIS_URL=redis://localhost:6379/0

# LLM 配置
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.deepseek.com

# 向量数据库配置
VECTOR_DB_TYPE=chroma
VECTOR_DB_PATH=./data/vectors

# 视觉模型配置
VISION_PROVIDER=openai
VISION_MODEL=gpt-4-vision-preview
VISION_API_KEY=your-vision-api-key-here
VISION_API_BASE=https://api.openai.com

# 飞书 Bot 配置
FEISHU_APP_ID=your-app-id
FEISHU_APP_SECRET=your-app-secret
FEISHU_VERIFY_TOKEN=your-verify-token

# 微信 Bot 配置
WECHAT_APP_ID=your-app-id
WECHAT_APP_SECRET=your-app-secret
WECHAT_VERIFY_TOKEN=your-verify-token

# 钉钉 Bot 配置
DINGTALK_APP_ID=your-app-id
DINGTALK_APP_SECRET=your-app-secret
DINGTALK_WEBHOOK_URL=your-webhook-url

# 存储配置
STORAGE_TYPE=local
STORAGE_PATH=./data/storage

# 安全配置
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
